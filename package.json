{
  "name": "trae-mcp-plugin",
  "displayName": "AI伟哥",
  "description": "一个带设置页面和对话反馈的 VS Code 插件",
  "repository": {
    "type": "git",
    "url": "https://github.com/example/trae-mcp-plugin"
  },
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:aiweige.panel"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "aiweige",
          "title": "AI伟哥",
          "icon": "media/aiweige.svg"
        }
      ]
    },
    "views": {
      "aiweige": [
        {
          "id": "aiweige.panel",
          "name": "AI伟哥"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.1",
    "express": "^4.21.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.9.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.6.3"
  }
}
